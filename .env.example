# ============================================================================
# Copy this file to `.env` and fill in real values. NEVER put real secrets here
# in .env.example — this file is committed to git.
# ============================================================================

# --- Angel One SmartAPI Credentials ---
# Get your API key from: https://developer.angelone.in
ANGEL_API_KEY=your_smartapi_key
ANGEL_CLIENT_ID=your_client_id        # trading account ID (e.g. A123456)
ANGEL_PIN=your_4_digit_pin
ANGEL_TOTP_SECRET=your_base32_totp_secret

# --- Database (Postgres + TimescaleDB via docker-compose) ---
POSTGRES_USER=equity
POSTGRES_PASSWORD=change_me
POSTGRES_DB=equity_swing
POSTGRES_PORT=5432
# SQLAlchemy/psycopg URL used by the backend
DATABASE_URL=postgresql+psycopg://equity:change_me@localhost:5432/equity_swing
# Old SQLite DB (kept only for the one-time daily/weekly migration)
SQLITE_PATH=data/equity_swing.db

# --- Notifications ---
# Push via ntfy.sh (free, no account): install the app, subscribe to your topic.
NTFY_TOPIC=your-unique-topic
# Email via Gmail App Password (Google Account -> Security -> App Passwords).
SMTP_USER=your.gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password
NOTIFY_EMAIL=your.gmail@gmail.com
